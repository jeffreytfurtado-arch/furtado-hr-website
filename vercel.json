{
  "buildCommand": "npm run build:vite",
  "outputDirectory": "dist/client",
  "installCommand": "npm install",
  "framework": null,
  "crons": [
    {
      "path": "/api/compliance-updates",
      "schedule": "0 8 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
